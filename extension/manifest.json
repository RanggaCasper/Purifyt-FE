{
  "manifest_version": 3,
  "name": "Purifyt – YouTube Judol Filter",
  "version": "1.0.0",
  "description": "Deteksi dan sembunyikan komentar judi online (judol) di YouTube menggunakan AI Purifyt.",
  "icons": {
    "16": "src/icons/logo.png",
    "48": "src/icons/logo.png",
    "128": "src/icons/logo.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:9000/*",
    "https://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "src/modules/config.js",
        "src/modules/scanner.js",
        "src/modules/spoiler.js",
        "src/content.js"
      ],
      "css": ["src/styles/spoiler.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/pages/popup.html",
    "default_icon": {
      "16": "src/icons/logo.png",
      "48": "src/icons/logo.png",
      "128": "src/icons/logo.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/icons/logo.png"],
      "matches": ["https://*.youtube.com/*"]
    }
  ]
}
